@model FabricaHilos.Models.Hilo

@{
    ViewData["Title"] = "Detalle del Hilo";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🎯 Detalle del Hilo</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
        <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <strong>@Model.Codigo</strong> — @Model.Nombre
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Codigo)</dt>
                    <dd class="col-sm-7"><span class="badge bg-secondary">@Model.Codigo</span></dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Nombre)</dt>
                    <dd class="col-sm-7">@Model.Nombre</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Descripcion)</dt>
                    <dd class="col-sm-7">@(Model.Descripcion ?? "—")</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Color)</dt>
                    <dd class="col-sm-7">@Model.Color</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.GramajePorRollo)</dt>
                    <dd class="col-sm-7">@Model.GramajePorRollo g</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Stock)</dt>
                    <dd class="col-sm-7">
                        <span class="badge @(Model.Stock < 10 ? "bg-danger" : "bg-success")">
                            @Model.Stock rollos
                        </span>
                    </dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Precio)</dt>
                    <dd class="col-sm-7">@Model.Precio.ToString("C")</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.FechaCreacion)</dt>
                    <dd class="col-sm-7">@Model.FechaCreacion.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Activo)</dt>
                    <dd class="col-sm-7">
                        @if (Model.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>
