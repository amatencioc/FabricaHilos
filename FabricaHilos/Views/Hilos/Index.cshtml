@model IEnumerable<FabricaHilos.Models.Hilo>

@{
    ViewData["Title"] = "Hilos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🎯 Catálogo de Hilos</h2>
    <a asp-action="Create" class="btn btn-primary">+ Nuevo Hilo</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-primary">
            <tr>
                <th>@Html.DisplayNameFor(m => m.First().Codigo)</th>
                <th>@Html.DisplayNameFor(m => m.First().Nombre)</th>
                <th>@Html.DisplayNameFor(m => m.First().Color)</th>
                <th>@Html.DisplayNameFor(m => m.First().GramajePorRollo)</th>
                <th>@Html.DisplayNameFor(m => m.First().Stock)</th>
                <th>@Html.DisplayNameFor(m => m.First().Precio)</th>
                <th>@Html.DisplayNameFor(m => m.First().Activo)</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var hilo in Model)
            {
                <tr>
                    <td><span class="badge bg-secondary">@hilo.Codigo</span></td>
                    <td>@hilo.Nombre</td>
                    <td>@hilo.Color</td>
                    <td>@hilo.GramajePorRollo g</td>
                    <td>
                        <span class="badge @(hilo.Stock < 10 ? "bg-danger" : "bg-success")">
                            @hilo.Stock rollos
                        </span>
                    </td>
                    <td>@hilo.Precio.ToString("C")</td>
                    <td>
                        @if (hilo.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@hilo.Id" class="btn btn-sm btn-outline-info">Ver</a>
                        <a asp-action="Edit" asp-route-id="@hilo.Id" class="btn btn-sm btn-outline-warning">Editar</a>
                        <a asp-action="Delete" asp-route-id="@hilo.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        No hay hilos registrados. <a asp-action="Create">Crear el primero</a>.
    </div>
}
