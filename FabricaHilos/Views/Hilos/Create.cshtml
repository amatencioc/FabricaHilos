@model FabricaHilos.Models.Hilo

@{
    ViewData["Title"] = "Nuevo Hilo";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🎯 Nuevo Hilo</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Codigo" class="form-label"></label>
                        <input asp-for="Codigo" class="form-control" placeholder="Ej: H-001" />
                        <span asp-validation-for="Codigo" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ej: Hilo Algodón Premium" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label"></label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Color" class="form-label"></label>
                        <input asp-for="Color" class="form-control" placeholder="Ej: Rojo, Azul, Blanco" />
                        <span asp-validation-for="Color" class="text-danger"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="GramajePorRollo" class="form-label"></label>
                            <input asp-for="GramajePorRollo" class="form-control" type="number" step="0.01" min="1" />
                            <span asp-validation-for="GramajePorRollo" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Stock" class="form-label"></label>
                            <input asp-for="Stock" class="form-control" type="number" min="0" />
                            <span asp-validation-for="Stock" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Precio" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Precio" class="form-control" type="number" step="0.01" min="0.01" />
                        </div>
                        <span asp-validation-for="Precio" class="text-danger"></span>
                    </div>
                    <div class="mb-3 form-check">
                        <input asp-for="Activo" class="form-check-input" type="checkbox" />
                        <label asp-for="Activo" class="form-check-label"></label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Guardar</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
