@model FabricaHilos.Models.Pedido

@{
    ViewData["Title"] = $"Pedido {Model.Numero}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📋 Pedido <span class="badge bg-secondary">@Model.Numero</span></h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
        <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-warning">
                <strong>Información del Pedido</strong>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Numero)</dt>
                    <dd class="col-sm-7">@Model.Numero</dd>

                    <dt class="col-sm-5">Cliente</dt>
                    <dd class="col-sm-7">@Model.Cliente?.NombreCompleto</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.FechaPedido)</dt>
                    <dd class="col-sm-7">@Model.FechaPedido.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.FechaEntrega)</dt>
                    <dd class="col-sm-7">@(Model.FechaEntrega.HasValue ? Model.FechaEntrega.Value.ToString("dd/MM/yyyy") : "—")</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Estado)</dt>
                    <dd class="col-sm-7">
                        @{
                            var badgeClass = Model.Estado switch
                            {
                                "Pendiente" => "bg-secondary",
                                "En Proceso" => "bg-primary",
                                "Completado" => "bg-success",
                                "Cancelado" => "bg-danger",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badgeClass">@Model.Estado</span>
                    </dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Total)</dt>
                    <dd class="col-sm-7"><strong>@Model.Total.ToString("C")</strong></dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Observaciones)</dt>
                    <dd class="col-sm-7">@(Model.Observaciones ?? "—")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-warning d-flex justify-content-between align-items-center">
                <strong>Detalle del Pedido</strong>
            </div>
            <div class="card-body">
                @if (Model.Detalles.Any())
                {
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr>
                                <th>Hilo</th>
                                <th>Cantidad</th>
                                <th>Precio Unit.</th>
                                <th>Subtotal</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detalle in Model.Detalles)
                            {
                                <tr>
                                    <td>@detalle.Hilo?.Nombre</td>
                                    <td>@detalle.Cantidad</td>
                                    <td>@detalle.PrecioUnitario.ToString("C")</td>
                                    <td>@detalle.Subtotal.ToString("C")</td>
                                    <td>
                                        <form asp-action="EliminarDetalle" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="detalleId" value="@detalle.Id" />
                                            <input type="hidden" name="pedidoId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('¿Eliminar este ítem?')">✕</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-active fw-bold">
                                <td colspan="3" class="text-end">Total:</td>
                                <td>@Model.Total.ToString("C")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                }
                else
                {
                    <p class="text-muted">No hay ítems en este pedido.</p>
                }

                <hr />
                <h6>Agregar Ítem</h6>
                <form asp-action="AgregarDetalle" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="pedidoId" value="@Model.Id" />
                    <div class="row g-2 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label small">Hilo</label>
                            <select name="hiloId" asp-items="ViewBag.Hilos" class="form-select form-select-sm">
                                <option value="">-- Hilo --</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small">Cantidad</label>
                            <input name="cantidad" type="number" min="1" value="1" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small">Precio Unit.</label>
                            <input name="precioUnitario" type="number" step="0.01" min="0.01" value="0.00" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-sm btn-success w-100">+ Agregar</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
