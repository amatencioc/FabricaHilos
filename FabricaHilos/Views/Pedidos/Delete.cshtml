@model FabricaHilos.Models.Pedido

@{
    ViewData["Title"] = "Eliminar Pedido";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📋 Eliminar Pedido</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white">
                ⚠️ ¿Está seguro que desea eliminar este pedido?
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Numero)</dt>
                    <dd class="col-sm-8">@Model.Numero</dd>
                    <dt class="col-sm-4">Cliente</dt>
                    <dd class="col-sm-8">@Model.Cliente?.NombreCompleto</dd>
                    <dt class="col-sm-4">@Html.DisplayNameFor(m => m.FechaPedido)</dt>
                    <dd class="col-sm-8">@Model.FechaPedido.ToString("dd/MM/yyyy")</dd>
                    <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Estado)</dt>
                    <dd class="col-sm-8">@Model.Estado</dd>
                    <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Total)</dt>
                    <dd class="col-sm-8">@Model.Total.ToString("C")</dd>
                </dl>

                <div class="alert alert-warning">
                    Esta acción eliminará también todos los ítems del pedido y no se puede deshacer.
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">Eliminar</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
