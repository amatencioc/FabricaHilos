@model FabricaHilos.Models.Material

@{
    ViewData["Title"] = "Detalle del Material";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🧪 Detalle del Material</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
        <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <strong>@Model.Nombre</strong>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Nombre)</dt>
                    <dd class="col-sm-7">@Model.Nombre</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Descripcion)</dt>
                    <dd class="col-sm-7">@(Model.Descripcion ?? "—")</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.UnidadMedida)</dt>
                    <dd class="col-sm-7">@Model.UnidadMedida</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Stock)</dt>
                    <dd class="col-sm-7">
                        <span class="badge @(Model.Stock < 10 ? "bg-danger" : "bg-success")">
                            @Model.Stock @Model.UnidadMedida
                        </span>
                    </dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.CostoUnitario)</dt>
                    <dd class="col-sm-7">@Model.CostoUnitario.ToString("C")</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Activo)</dt>
                    <dd class="col-sm-7">
                        @if (Model.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>
