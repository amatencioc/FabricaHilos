@model IEnumerable<FabricaHilos.Models.Cliente>

@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>👥 Clientes</h2>
    <a asp-action="Create" class="btn btn-info text-white">+ Nuevo Cliente</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-info">
            <tr>
                <th>Nombre Completo</th>
                <th>@Html.DisplayNameFor(m => m.First().Email)</th>
                <th>@Html.DisplayNameFor(m => m.First().Telefono)</th>
                <th>@Html.DisplayNameFor(m => m.First().FechaRegistro)</th>
                <th>@Html.DisplayNameFor(m => m.First().Activo)</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cliente in Model)
            {
                <tr>
                    <td>@cliente.NombreCompleto</td>
                    <td>@cliente.Email</td>
                    <td>@(cliente.Telefono ?? "—")</td>
                    <td>@cliente.FechaRegistro.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (cliente.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@cliente.Id" class="btn btn-sm btn-outline-info">Ver</a>
                        <a asp-action="Edit" asp-route-id="@cliente.Id" class="btn btn-sm btn-outline-warning">Editar</a>
                        <a asp-action="Delete" asp-route-id="@cliente.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        No hay clientes registrados. <a asp-action="Create">Crear el primero</a>.
    </div>
}
