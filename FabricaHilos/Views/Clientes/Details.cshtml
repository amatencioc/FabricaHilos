@model FabricaHilos.Models.Cliente

@{
    ViewData["Title"] = "Detalle del Cliente";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>👥 Detalle del Cliente</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
        <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white">
                <strong>@Model.NombreCompleto</strong>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Nombre)</dt>
                    <dd class="col-sm-7">@Model.Nombre</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Apellido)</dt>
                    <dd class="col-sm-7">@Model.Apellido</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Email)</dt>
                    <dd class="col-sm-7"><a href="mailto:@Model.Email">@Model.Email</a></dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Telefono)</dt>
                    <dd class="col-sm-7">@(Model.Telefono ?? "—")</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Direccion)</dt>
                    <dd class="col-sm-7">@(Model.Direccion ?? "—")</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.FechaRegistro)</dt>
                    <dd class="col-sm-7">@Model.FechaRegistro.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Activo)</dt>
                    <dd class="col-sm-7">
                        @if (Model.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>
