@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión - Fábrica de Hilos</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="login-page">
<div class="min-vh-100 d-flex align-items-center justify-content-center p-4">
    <div class="w-100" style="max-width: 420px;">
        <div class="text-center mb-4">
            <i class="bi bi-threads display-3 text-warning"></i>
            <h2 class="text-white fw-bold mt-2">Fábrica de Hilos</h2>
            <p class="text-white-50">Sistema de Gestión Empresarial</p>
        </div>

        <div class="card login-card p-4">
            <h5 class="card-title text-center mb-4 fw-bold" style="color: #1a3a5c;">
                <i class="bi bi-person-circle me-2"></i>Iniciar Sesión
            </h5>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div><i class="bi bi-exclamation-triangle me-1"></i>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form method="post" asp-action="Login" asp-controller="Account">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Correo Electrónico</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input type="email" name="email" class="form-control" placeholder="correo@fabricahilos.com" required autocomplete="username" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Contraseña</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input type="password" name="password" class="form-control" placeholder="••••••••" required autocomplete="current-password" />
                    </div>
                </div>

                <div class="mb-3 form-check">
                    <input type="checkbox" name="recordarme" class="form-check-input" id="recordarme" value="true" />
                    <label class="form-check-label" for="recordarme">Recordarme</label>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-lg fw-bold" style="background-color: #1a3a5c; color: white;">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Ingresar
                    </button>
                </div>
            </form>

            <hr class="my-3" />
            <div class="text-center">
                <small class="text-muted">
                    <i class="bi bi-info-circle me-1"></i>
                    Credenciales por defecto: <strong>admin@fabricahilos.com</strong> / <strong>Admin123!</strong>
                </small>
            </div>
        </div>

        <div class="text-center mt-3">
            <small class="text-white-50">&copy; @DateTime.Now.Year Fábrica de Hilos</small>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
