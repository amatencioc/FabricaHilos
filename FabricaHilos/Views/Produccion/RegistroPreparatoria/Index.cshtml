@model IEnumerable<FabricaHilos.Services.Produccion.PreparatoriaListDto>
@using FabricaHilos.Helpers

@{
    ViewData["Title"] = "Registro de Preparatoria";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Produccion" asp-action="Index">Producción</a></li>
    <li class="breadcrumb-item active">Registro de Preparatoria</li>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="section-title mb-0"><i class="bi bi-gear-wide-connected me-2"></i>Registro de Preparatoria</h4>
    @if (User.IsInRole("Admin") || User.IsInRole("Gerencia") || User.IsInRole("Supervisor"))
    {
        <a asp-action="Crear" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Nuevo
        </a>
    }
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2 flex-wrap">
            <input type="text" name="buscar" value="@ViewBag.Buscar" class="form-control form-control-sm" placeholder="Buscar por lote..." style="max-width: 220px;" />
            <select name="tipoMaquina" class="form-select form-select-sm" style="max-width: 220px;"
                    onchange="document.querySelector('[name=maquina]').value=''; this.form.submit();">
                <option value="">Todos los tipos</option>
                @if (ViewBag.TiposMaquinasFiltro != null)
                {
                    @foreach (var tipo in ViewBag.TiposMaquinasFiltro)
                    {
                        <option value="@tipo.TipoMaquina" selected="@(ViewBag.TipoMaquinaFiltro == tipo.TipoMaquina)">@tipo.TextoCompleto</option>
                    }
                }
            </select>
            <select name="maquina" class="form-select form-select-sm" style="max-width: 220px;">
                <option value="">Todas las máquinas</option>
                @if (ViewBag.Maquinas != null)
                {
                    @foreach (var maq in ViewBag.Maquinas)
                    {
                        <option value="@maq.Codigo" selected="@(ViewBag.MaquinaFiltro == maq.Codigo)">@maq.Descripcion</option>
                    }
                }
            </select>
            <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-search"></i> Filtrar</button>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-corporate table-hover mb-0">
                <thead>
                    <tr>
                        <th>Receta</th>
                        <th>Lote</th>
                        <th>Material</th>
                        <th>Máquina</th>
                        <th>Título</th>
                        <th>Fecha Inicial</th>
                        <th>Turno</th>
                        <th>Operario</th>
                        <th>Paso</th>
                        @*<th>Estado</th>*@
                        @if (User.IsInRole("Admin") || User.IsInRole("Gerencia") || User.IsInRole("Supervisor"))
                        {
                            <th>Acciones</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @* Datos de la base de datos *@
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Receta</td>
                                <td>@(item.Lote ?? "-")</td>
                                <td>@(item.Material ?? "-")</td>
                                <td>@(string.IsNullOrEmpty(item.DescripcionMaquina) ? "-" : item.DescripcionMaquina)</td>
                                <td>@(string.IsNullOrEmpty(item.DescripcionTitulo) ? "-" : item.DescripcionTitulo)</td>
                                <td>@item.FechaInicio.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td>@(item.Turno == null ? "-" : ProduccionLookups.GetTurno(item.Turno))</td>
                                <td>@(string.IsNullOrEmpty(item.NombreOperario) ? "-" : item.NombreOperario)</td>
                                <td>@(item.PasoManual == null ? "-" : ProduccionLookups.GetPaso(item.PasoManual))</td>
                                @*<td>
                                    @{
                                        var estadoClass = item.Estado switch
                                        {
                                            "1" => new { Class = "bg-primary", Icon = "bi-gear-fill", Text = "En Proceso" },
                                            "3" => new { Class = "bg-success", Icon = "bi-check-circle", Text = "Completado" },
                                            "9" => new { Class = "bg-danger", Icon = "bi-x-circle", Text = "Anulado" },
                                            _ => new { Class = "bg-secondary", Icon = "bi-question-circle", Text = "Desconocido" }
                                        };
                                    }
                                    <span class="badge @estadoClass.Class">
                                        <i class="bi @estadoClass.Icon me-1"></i>@estadoClass.Text
                                    </span>
                                </td>*@
                                @if (User.IsInRole("Admin") || User.IsInRole("Gerencia") || User.IsInRole("Supervisor"))
                                {
                                    <td>
                                        @if (item.LocalId.HasValue)
                                        {
                                            <a asp-action="Editar" asp-route-id="@item.LocalId" class="btn btn-sm btn-outline-primary me-1" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="DetalleProduccion" asp-route-id="@item.LocalId" class="btn btn-sm btn-outline-info me-1" title="Detalle de Producción">
                                                <i class="bi bi-bar-chart-line"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-warning me-1 btn-paradas"
                                                    data-id="@item.LocalId"
                                                    title="Agregar Número de Paradas">
                                                <i class="bi bi-sign-stop"></i> Nº Paradas
                                            </button>
                                            @if (User.IsInRole("Admin") || User.IsInRole("Gerencia"))
                                            {
                                                <form asp-action="Anular" asp-route-id="@item.LocalId" method="post" class="d-inline"
                                                      onsubmit="return confirm('¿Anular esta preparatoria?');">  
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-danger" title="Anular Preparatoria">
                                                        <i class="bi bi-slash-circle"></i>
                                                    </button>
                                                </form>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Oracle</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="11" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                No hay registros de preparatoria.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Nº Paradas -->
<div class="modal fade" id="modalParadas" tabindex="-1" aria-labelledby="modalParadasLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalParadasLabel"><i class="bi bi-sign-stop me-2"></i>Número de Paradas</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-5">
                        <label class="form-label fw-semibold">Nº Parada</label>
                        <input type="number" id="inputNumeroParada" class="form-control" min="1" placeholder="Número de parada" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label fw-semibold">Metraje</label>
                        <input type="number" id="inputMetrajeParada" class="form-control" step="0.01" min="0" placeholder="Metraje" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="button" id="btnAgregarParada" class="btn btn-primary w-100">
                            <i class="bi bi-plus-circle me-1"></i>Agregar
                        </button>
                    </div>
                </div>
                <div id="alertaParada" class="alert d-none" role="alert"></div>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:50%">Nº Parada</th>
                                <th style="width:40%">Metraje</th>
                                <th style="width:10%"></th>
                            </tr>
                        </thead>
                        <tbody id="tablaParadas">
                            <tr id="filaVaciaParadas">
                                <td colspan="3" class="text-center text-muted small py-3">Sin paradas registradas</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" id="btnGuardarParadas" class="btn btn-success px-4">
                    <i class="bi bi-save me-1"></i>Guardar
                </button>
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>Cerrar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const urlObtenerParadas  = '@Url.Action("ObtenerParadas",  "RegistroPreparatoria")';
    const urlGuardarParadas  = '@Url.Action("GuardarParadas",  "RegistroPreparatoria")';

    let paradaOrdenId = null;
    let listaParadas  = [];   // { numeroParada, metraje }

    function mostrarAlertaParada(mensaje, tipo) {
        const el = document.getElementById('alertaParada');
        el.textContent = mensaje;
        el.className = `alert alert-${tipo}`;
    }

    function ocultarAlertaParada() {
        const el = document.getElementById('alertaParada');
        el.className = 'alert d-none';
    }

    function renderizarParadas() {
        const tbody = document.getElementById('tablaParadas');
        tbody.innerHTML = '';

        if (listaParadas.length === 0) {
            tbody.innerHTML = '<tr id="filaVaciaParadas"><td colspan="3" class="text-center text-muted small py-3">Sin paradas registradas</td></tr>';
            return;
        }

        listaParadas.forEach(function (p, idx) {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${p.numeroParada}</td>
                <td>${p.metraje}</td>
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-outline-danger btn-eliminar-parada" data-idx="${idx}" title="Eliminar">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>`;
            tbody.appendChild(tr);
        });

        tbody.querySelectorAll('.btn-eliminar-parada').forEach(function (btn) {
            btn.addEventListener('click', function () {
                listaParadas.splice(parseInt(this.dataset.idx), 1);
                renderizarParadas();
                ocultarAlertaParada();
            });
        });
    }

    async function cargarParadas(id) {
        listaParadas = [];
        renderizarParadas();
        try {
            const resp = await fetch(`${urlObtenerParadas}?id=${id}`);
            const result = await resp.json();
            if (result.success && result.data) {
                listaParadas = result.data.map(function (p) {
                    return { numeroParada: p.numeroParada, metraje: parseFloat(p.metraje) };
                });
                renderizarParadas();
            }
        } catch (err) {
            console.error('Error cargando paradas:', err);
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        // Abrir modal al hacer clic en cualquier botón Nº Paradas
        document.querySelectorAll('.btn-paradas').forEach(function (btn) {
            btn.addEventListener('click', async function () {
                paradaOrdenId = parseInt(this.dataset.id);
                ocultarAlertaParada();
                document.getElementById('inputNumeroParada').value = '';
                document.getElementById('inputMetrajeParada').value = '';
                await cargarParadas(paradaOrdenId);
                var modal = new bootstrap.Modal(document.getElementById('modalParadas'));
                modal.show();
            });
        });

        // Agregar parada a la lista en memoria
        document.getElementById('btnAgregarParada').addEventListener('click', function () {
            const numInput     = document.getElementById('inputNumeroParada');
            const metrajeInput = document.getElementById('inputMetrajeParada');
            const numero       = parseInt(numInput.value);
            const metraje      = parseFloat(metrajeInput.value);

            if (isNaN(numero) || numero <= 0) {
                mostrarAlertaParada('Ingrese un número de parada válido (mayor a 0).', 'warning');
                numInput.focus();
                return;
            }
            if (isNaN(metraje) || metraje < 0) {
                mostrarAlertaParada('Ingrese un metraje válido (mayor o igual a 0).', 'warning');
                metrajeInput.focus();
                return;
            }

            listaParadas.push({ numeroParada: numero, metraje: metraje });
            renderizarParadas();
            ocultarAlertaParada();
            numInput.value     = '';
            metrajeInput.value = '';
            numInput.focus();
        });

        // Guardar paradas en el servidor
        document.getElementById('btnGuardarParadas').addEventListener('click', async function () {
            const btn = this;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando...';

            try {
                const resp = await fetch(`${urlGuardarParadas}?id=${paradaOrdenId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(listaParadas)
                });
                const result = await resp.json();

                if (result.success) {
                    mostrarAlertaParada('Paradas guardadas correctamente.', 'success');
                } else {
                    mostrarAlertaParada('Error al guardar: ' + (result.message || 'Error desconocido.'), 'danger');
                }
            } catch (err) {
                mostrarAlertaParada('Error de conexión al guardar las paradas.', 'danger');
                console.error(err);
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-save me-1"></i>Guardar';
            }
        });
    });
</script>
}

