@model FabricaHilos.Models.Produccion.OrdenProduccion
@using FabricaHilos.Models.Produccion

@{
    ViewData["Title"] = "Nueva Orden de Producción";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-action="Index">Producción</a></li>
    <li class="breadcrumb-item active">Nueva Orden</li>
}

<h4 class="section-title"><i class="bi bi-plus-circle me-2"></i>Nueva Orden de Producción</h4>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NumeroOrden" class="form-label fw-semibold"></label>
                            <input asp-for="NumeroOrden" class="form-control" value="@ViewBag.NumeroOrden" />
                            <span asp-validation-for="NumeroOrden" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TipoHilo" class="form-label fw-semibold"></label>
                            <input asp-for="TipoHilo" class="form-control" placeholder="ej: Hilo de algodón Ne 30/1" />
                            <span asp-validation-for="TipoHilo" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FechaInicio" class="form-label fw-semibold"></label>
                            <input asp-for="FechaInicio" class="form-control" type="date" />
                            <span asp-validation-for="FechaInicio" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FechaFinEstimada" class="form-label fw-semibold"></label>
                            <input asp-for="FechaFinEstimada" class="form-control" type="date" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CantidadPlanificada" class="form-label fw-semibold"></label>
                            <input asp-for="CantidadPlanificada" class="form-control" type="number" step="0.01" min="0" />
                            <span asp-validation-for="CantidadPlanificada" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CantidadProducida" class="form-label fw-semibold"></label>
                            <input asp-for="CantidadProducida" class="form-control" type="number" step="0.01" min="0" value="0" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Estado" class="form-label fw-semibold"></label>
                            <select asp-for="Estado" class="form-select">
                                @foreach (var e in Enum.GetValues<EstadoOrden>())
                                {
                                    <option value="@e">@e</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EmpleadoId" class="form-label fw-semibold"></label>
                            <select asp-for="EmpleadoId" class="form-select">
                                <option value="">-- Sin asignar --</option>
                                @if (ViewBag.Empleados != null)
                                {
                                    @foreach (var emp in ViewBag.Empleados)
                                    {
                                        <option value="@emp.Id">@emp.NombreCompleto</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Observaciones" class="form-label fw-semibold"></label>
                            <textarea asp-for="Observaciones" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Guardar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
