@model IEnumerable<FabricaHilos.Models.Produccion.OrdenProduccion>
@using FabricaHilos.Models.Produccion

@{
    ViewData["Title"] = "Producción";
}

@section Breadcrumb {
    <li class="breadcrumb-item active">Producción</li>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="section-title mb-0"><i class="bi bi-gear-wide-connected me-2"></i>Órdenes de Producción</h4>
    @if (User.IsInRole("Admin") || User.IsInRole("Gerencia") || User.IsInRole("Supervisor"))
    {
        <a asp-action="Crear" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Nueva Orden
        </a>
    }
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2 flex-wrap">
            <input type="text" name="buscar" value="@ViewBag.Buscar" class="form-control form-control-sm" placeholder="Buscar por número o tipo de hilo..." style="max-width: 280px;" />
            <select name="estado" class="form-select form-select-sm" style="max-width: 160px;">
                <option value="">Todos los estados</option>
                @foreach (var e in Enum.GetValues<EstadoOrden>())
                {
                    <option value="@e" selected="@(ViewBag.EstadoFiltro?.ToString() == e.ToString())">@e</option>
                }
            </select>
            <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-search"></i> Filtrar</button>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-corporate table-hover mb-0">
                <thead>
                    <tr>
                        <th>N° Orden</th>
                        <th>Tipo de Hilo</th>
                        <th>Fecha Inicio</th>
                        <th>Fecha Fin Est.</th>
                        <th>Cant. Planificada</th>
                        <th>Cant. Producida</th>
                        <th>Responsable</th>
                        <th>Estado</th>
                        @if (User.IsInRole("Admin") || User.IsInRole("Gerencia") || User.IsInRole("Supervisor"))
                        {
                            <th>Acciones</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.NumeroOrden</td>
                            <td>@item.TipoHilo</td>
                            <td>@item.FechaInicio.ToString("dd/MM/yyyy")</td>
                            <td>@(item.FechaFinEstimada?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td>@item.CantidadPlanificada.ToString("N2")</td>
                            <td>@item.CantidadProducida.ToString("N2")</td>
                            <td>@(item.Empleado?.NombreCompleto ?? "-")</td>
                            <td>
                                @{
                                    var estadoClass = item.Estado switch
                                    {
                                        EstadoOrden.Pendiente => "bg-warning text-dark",
                                        EstadoOrden.EnProceso => "bg-primary",
                                        EstadoOrden.Completada => "bg-success",
                                        EstadoOrden.Cancelada => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @estadoClass">@item.Estado</span>
                            </td>
                            @if (User.IsInRole("Admin") || User.IsInRole("Gerencia") || User.IsInRole("Supervisor"))
                            {
                                <td>
                                    <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary btn-accion">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Gerencia"))
                                    {
                                        <form method="post" asp-action="Eliminar" asp-route-id="@item.Id" class="d-inline"
                                              onsubmit="return confirm('¿Eliminar esta orden de producción?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger btn-accion">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            }
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay órdenes de producción registradas.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
